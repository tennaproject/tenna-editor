{
  "name": "tenna-editor",
  "private": false,
  "version": "0.9.0-beta",
  "type": "module",
  "engines": {
    "node": ">=22.16.0",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "update-contributors": "node scripts/contributors.ts",
    "check-contributors": "npm run update-contributors && git diff --exit-code -- CONTRIBUTORS.md src/data/contributors.ts",
    "preview": "vite preview",
    "generate-pwa-assets": "pwa-assets-generator",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "clsx": "^2.1.1",
    "color-convert": "^3.1.3",
    "downshift": "^9.3.6",
    "fast-glob": "^3.3.3",
    "framer-motion": "^12.40.0",
    "idb": "^8.0.3",
    "immer": "^11.1.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.11",
    "vite-plugin-pwa": "^1.3.0",
    "zustand": "^5.0.14",
    "zustand-debounce": "^2.3.1"
